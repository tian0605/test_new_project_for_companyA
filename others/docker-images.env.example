MYEMS_MQTT_IMAGE=registry.example.com/myems/mqtt:release-tag
MYEMS_NORMALIZATION_IMAGE=registry.example.com/myems/normalization:release-tag
MYEMS_ADMIN_IMAGE=registry.example.com/myems/admin:release-tag
MYEMS_WEB_IMAGE=registry.example.com/myems/web:release-tag